# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sanity CMS (Phase 4)
# Create a project at https://sanity.io/manage → copy the project ID
NEXT_PUBLIC_SANITY_PROJECT_ID=
# Dataset name — "production" by default
NEXT_PUBLIC_SANITY_DATASET=production
# API version — date string, e.g. "2024-01-01"
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
# Viewer token for ISR + draft mode (create at sanity.io/manage → API → Tokens)
SANITY_API_READ_TOKEN=

# Stripe (Phase 7)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend (Phase 3)
# RESEND_API_KEY=
